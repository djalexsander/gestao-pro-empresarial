{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissões base do Gestão Pro Desktop. Inclui updater + process para fluxo de atualização in-app.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "store:allow-has",
    "store:allow-delete",
    "store:allow-clear",
    "store:allow-keys",
    "store:allow-entries",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "dialog:default",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-write-text-file"
  ]
}
