{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissões base mínimas do Gestão Pro Desktop. Adicionar mais quando necessário (fs, dialog, http, etc.).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "store:allow-has",
    "store:allow-delete",
    "store:allow-clear",
    "store:allow-keys",
    "store:allow-entries"
  ]
}
