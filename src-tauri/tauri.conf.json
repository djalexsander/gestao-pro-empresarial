{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gestão Pro",
  "version": "1.0.0",
  "identifier": "com.alexproapps.gestaopro",
  "build": {
    "beforeDevCommand": "npm run dev:desktop",
    "devUrl": "http://localhost:5173",
    "frontendDist": "tauri-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gestão Pro",
        "width": 1366,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "Sistema de gestão empresarial",
    "longDescription": "Gestão Pro — sistema completo de gestão: estoque, vendas, compras, financeiro e relatórios.",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://gestao-pro-empresarial.alexproapps.com.br/releases/latest.json",
        "https://gestao-pro-empresarial.lovable.app/releases/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
    }
  }
}
