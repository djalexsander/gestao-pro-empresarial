{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gestão Pro",
  "version": "1.1.3",
  "identifier": "com.alexproapps.gestaopro",
  "build": {
    "beforeDevCommand": "npm run dev:desktop",
    "devUrl": "http://localhost:8080",
    "frontendDist": "tauri-dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gestão Pro",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "Sistema de gestão empresarial",
    "longDescription": "Gestão Pro — sistema completo de gestão: estoque, vendas, compras, financeiro e relatórios.",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/djalexsander/gestao-pro-empresarial/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1Mjc3REU5MDM3RTcwMgpSV1FDNXplUTNuZFNCS1EzOENLeGRCUWRWRkFheUZOVHBRUy9od1oxTkJGTWp6dzNjOWhvYmhocwo="
    }
  }
}
